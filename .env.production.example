# Production environment for stream.rodion.pro

# Database
DATABASE_URL=postgresql://stream_user:STRONG_PASSWORD_HERE@localhost:5432/stream_rodion

# Server
PORT=3012
NODE_ENV=production

# Admin auth
# Generate with: node -e "require('bcrypt').hash('yourpassword', 10).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=$2b$10$REPLACE_WITH_BCRYPT_HASH
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_SECRET

# Kick (fill when ready for integration)
KICK_CHANNEL_SLUG=wizardjiocb
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=https://stream.rodion.pro/api/auth/kick/callback
KICK_WEBHOOK_SECRET=

# Site
SITE_URL=https://stream.rodion.pro
