    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@tanstack/react-query": "^5.62.0",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
