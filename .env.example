# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stream_rodion

# Server
PORT=3012
NODE_ENV=development

# Admin auth
# Generate with: node -e "require('bcrypt').hash('yourpassword', 10).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=$2b$10$REPLACE_WITH_BCRYPT_HASH
JWT_SECRET=replace-with-random-secret-min-32-chars

# Kick (prepared for future integration)
KICK_CHANNEL_SLUG=wizardjiocb
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=
KICK_WEBHOOK_SECRET=

# Site
